# ──────────────────────────────────────────────────────────────
# Backend (Render / Docker)
# ──────────────────────────────────────────────────────────────

# Neon PostgreSQL connection string (required)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# OpenAI API key for tender extraction (required for AI extraction)
# Leave empty to use keyword-based fallback extraction
OPENAI_API_KEY=sk-...

# OpenAI model to use (optional, defaults to gpt-4.1-mini)
OPENAI_MODEL=gpt-4.1-mini

# ──────────────────────────────────────────────────────────────
# Cloudflare R2 file storage (optional)
# If any of these are missing, uploads are skipped gracefully
# ──────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=tender-uploads

# ──────────────────────────────────────────────────────────────
# Security
# ──────────────────────────────────────────────────────────────

# Set to "true" on production (HTTPS only)
SESSION_COOKIE_SECURE=false

# Use "none" when the API and frontend are on different domains (cross-origin cookies)
# Use "lax" when same domain (e.g. both on *.yourdomain.com)
SESSION_COOKIE_SAMESITE=none

# Comma-separated list of allowed CORS origins (your Cloudflare Pages URL)
CORS_ORIGINS=https://your-portfolio.pages.dev,https://yourdomain.com

# ──────────────────────────────────────────────────────────────
# App tuning (optional)
# ──────────────────────────────────────────────────────────────

# Seconds before OCR / OpenAI extraction times out (default: 60)
EXTRACTION_TIMEOUT_SECONDS=60

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
